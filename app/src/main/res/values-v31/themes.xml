<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.JokersEscapeRoom" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#0A0A0A</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#00000000</item>

        <!-- Android 12+ system splash screen -->
        <!-- Black bg so the mandatory circle blends away -->
        <item name="android:windowSplashScreenBackground">#0A0A0A</item>
        <!-- Joker icon centered on the splash -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_joker_icon</item>
        <!-- Match background so the white icon circle is invisible -->
        <item name="android:windowSplashScreenIconBackgroundColor">#0A0A0A</item>
    </style>

</resources>
